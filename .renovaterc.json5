{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>GiorgioAresu/renovate-config",
    "github>GiorgioAresu/home-ops//.renovate/overrides.json5",
    "github>GiorgioAresu/home-ops//.renovate/groups.json5",
    "github>GiorgioAresu/home-ops//.renovate/autoMerge.json5",
    "github>GiorgioAresu/home-ops//.renovate/customManagers.json5",
    "github>GiorgioAresu/home-ops//.renovate/grafanaDashboards.json5",
  ],
  flux: {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  }
}
