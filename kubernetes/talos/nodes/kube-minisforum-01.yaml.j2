---
machine:
  install:
    diskSelector:
      model: KINGSTON OM8PGP41024Q-A0
  type: controlplane
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: kube-minisforum-01
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
    match: link.driver == "r8169" && mac(link.permanent_addr).startsWith("58:47:ca:78:51:3f")
